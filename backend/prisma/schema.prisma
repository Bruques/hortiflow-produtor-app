generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PapelSocio {
  FINANCIADOR
  MEEIRO
  MISTO
}

enum StatusSafra {
  PLANEJADA
  EM_ANDAMENTO
  ENCERRADA
}

enum TipoDespesa {
  TERRA
  MUDAS
  ADUBO
  DEFENSIVOS
  MAO_DE_OBRA
  EMBALAGEM
  TRANSPORTE
  OUTRO
}

enum TipoAcerto {
  PARCIAL
  FINAL
}

enum TipoGatilhoRegra {
  POR_VENDA
  POR_PERIODO
}

model Usuario {
  id         String   @id @default(uuid())
  nome       String
  telefone   String   @unique
  senha_hash String
  criado_em  DateTime @default(now())

  socioSociedades  SocioSociedade[]
  despesas         Despesa[]
  despesasPessoais DespesaPessoal[]
  aportesTrabalho  AporteTrabalho[]
  regrasComoSocio  RegraDespesaRecorrente[] @relation("RegraSocio")
  regrasCriadas    RegraDespesaRecorrente[] @relation("RegraCriador")

  @@map("usuarios")
}

model Sociedade {
  id             String   @id @default(uuid())
  nome           String
  codigo_convite String   @unique
  criado_em      DateTime @default(now())

  socios            SocioSociedade[]
  safras            Safra[]
  regrasRecorrentes RegraDespesaRecorrente[]
  unidadesVenda     UnidadeVenda[]

  @@map("sociedades")
}

model SocioSociedade {
  id               String     @id @default(uuid())
  usuario_id       String?
  nome             String?
  sociedade_id     String
  percentual_lucro Decimal    @db.Decimal(5, 2)
  papel            PapelSocio
  criado_em        DateTime   @default(now())

  usuario      Usuario?      @relation(fields: [usuario_id], references: [id])
  sociedade    Sociedade     @relation(fields: [sociedade_id], references: [id])
  acertoSocios AcertoSocio[]

  @@unique([usuario_id, sociedade_id])
  @@map("socio_sociedades")
}

model Safra {
  id           String      @id @default(uuid())
  sociedade_id String
  nome         String
  observacoes  String?
  status       StatusSafra @default(PLANEJADA)
  data_inicio  DateTime?
  data_fim     DateTime?
  criado_em    DateTime    @default(now())

  sociedade        Sociedade        @relation(fields: [sociedade_id], references: [id])
  despesas         Despesa[]
  despesasPessoais DespesaPessoal[]
  vendas           Venda[]
  acertos          Acerto[]
  aportesTrabalho  AporteTrabalho[]

  @@map("safras")
}

model Despesa {
  id               String      @id @default(uuid())
  safra_id         String
  socio_id         String
  tipo             TipoDespesa
  valor            Decimal     @db.Decimal(10, 2)
  data             DateTime
  foto_comprovante String?
  descricao        String?
  regra_origem_id  String?
  venda_origem_id  String?
  criado_em        DateTime    @default(now())

  safra       Safra                   @relation(fields: [safra_id], references: [id])
  socio       Usuario                 @relation(fields: [socio_id], references: [id])
  regraOrigem RegraDespesaRecorrente? @relation(fields: [regra_origem_id], references: [id])
  vendaOrigem Venda?                  @relation(fields: [venda_origem_id], references: [id])

  @@map("despesas")
}

model DespesaPessoal {
  id         String      @id @default(uuid())
  safra_id   String
  usuario_id String
  tipo       TipoDespesa
  valor      Decimal     @db.Decimal(10, 2)
  data       DateTime
  descricao  String?
  criado_em  DateTime    @default(now())

  safra   Safra   @relation(fields: [safra_id], references: [id])
  usuario Usuario @relation(fields: [usuario_id], references: [id])

  @@map("despesas_pessoais")
}

model AporteTrabalho {
  id        String   @id @default(uuid())
  safra_id  String
  socio_id  String
  data      DateTime
  horas     Decimal  @db.Decimal(5, 2)
  descricao String?
  criado_em DateTime @default(now())

  safra Safra   @relation(fields: [safra_id], references: [id])
  socio Usuario @relation(fields: [socio_id], references: [id])

  @@map("aportes_trabalho")
}

model Venda {
  id         String   @id @default(uuid())
  safra_id   String
  unidade_id String
  data       DateTime
  quantidade Decimal  @db.Decimal(10, 2)
  preco      Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)
  comprador  String?
  pago       Boolean  @default(false)
  criado_em  DateTime @default(now())

  safra           Safra        @relation(fields: [safra_id], references: [id])
  unidade         UnidadeVenda @relation(fields: [unidade_id], references: [id])
  despesasGeradas Despesa[]

  @@map("vendas")
}

model UnidadeVenda {
  id           String   @id @default(uuid())
  sociedade_id String
  nome         String
  ativo        Boolean  @default(true)
  criado_em    DateTime @default(now())

  sociedade Sociedade                @relation(fields: [sociedade_id], references: [id])
  vendas    Venda[]
  regras    RegraDespesaRecorrente[]

  @@unique([sociedade_id, nome])
  @@map("unidades_venda")
}

model RegraDespesaRecorrente {
  id           String           @id @default(uuid())
  sociedade_id String
  socio_id     String
  criado_por   String
  tipo_gatilho TipoGatilhoRegra
  tipo_despesa TipoDespesa
  valor        Decimal          @db.Decimal(10, 2)
  unidade_id   String?
  ativo        Boolean          @default(true)
  criado_em    DateTime         @default(now())

  sociedade Sociedade     @relation(fields: [sociedade_id], references: [id])
  socio     Usuario       @relation("RegraSocio", fields: [socio_id], references: [id])
  criador   Usuario       @relation("RegraCriador", fields: [criado_por], references: [id])
  unidade   UnidadeVenda? @relation(fields: [unidade_id], references: [id])
  despesas  Despesa[]

  @@map("regras_despesa_recorrente")
}

model Acerto {
  id          String     @id @default(uuid())
  safra_id    String
  data_inicio DateTime
  data_fim    DateTime
  tipo        TipoAcerto
  criado_em   DateTime   @default(now())

  safra  Safra         @relation(fields: [safra_id], references: [id])
  socios AcertoSocio[]

  @@map("acertos")
}

model AcertoSocio {
  id                  String  @id @default(uuid())
  acerto_id           String
  socio_id            String
  despesas_bancadas   Decimal @db.Decimal(10, 2)
  percentual_aplicado Decimal @db.Decimal(5, 2)
  valor_lucro         Decimal @db.Decimal(10, 2)

  acerto Acerto         @relation(fields: [acerto_id], references: [id])
  socio  SocioSociedade @relation(fields: [socio_id], references: [id])

  @@map("acerto_socios")
}
